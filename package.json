{
  "name": "salon-app",
  "version": "1.0.0",
  "description": "A comprehensive beauty salon management desktop application",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "react-test": "react-scripts test",
    "react-eject": "react-scripts eject",
    "electron-start": "electron .",
    "electron-dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-build": "npm run react-build && electron-builder",
    "start": "concurrently \"npm run server\" \"npm run electron-dev\"",
    "build": "npm run electron-build",
    "server": "node backend/server.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "axios": "^1.3.0",
    "date-fns": "^2.29.3",
    "chart.js": "^3.9.1",
    "react-chartjs-2": "^4.0.1",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^7.6.0",
    "wait-on": "^7.0.1"
  },
  "overrides": {
    "html-webpack-plugin": "5.5.4"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "author": "busseozgenoglu-cyber",
  "license": "ISC",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
