    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^7.6.0",
    "wait-on": "^7.0.1"
  },
  "author": "busseozgenoglu-cyber",
